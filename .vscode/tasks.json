{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run all tests",
			"type": "shell",
			"command": "pytest",
			"isBackground": false,
			"problemMatcher": [
				"$pytest"
			],
			"group": "test"
		},
		{
			"label": "Run frontend tests",
			"type": "shell",
			"command": "npm run test",
			"isBackground": false,
			"problemMatcher": [
				"$eslint-stylish"
			],
			"group": "test"
		}
	]
}